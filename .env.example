# ============================================================
# Job Application Agent — Environment Variables
# ============================================================
# Copy to .env (gitignored) and fill in real values.
# NEVER commit real credentials to Git.
# ============================================================

# ---- Applicant Profile ----
APPLICANT_FIRST_NAME=YourFirstName
APPLICANT_LAST_NAME=YourLastName
APPLICANT_EMAIL=you@example.com
APPLICANT_PHONE=+972XXXXXXXXX
APPLICANT_CITY=YourCity
APPLICANT_LINKEDIN_URL=https://www.linkedin.com/in/your-profile/
APPLICANT_GITHUB_URL=https://github.com/your-username
APPLICANT_PORTFOLIO_URL=
APPLICANT_YEARS_EXPERIENCE=0

# ---- Google Service Account (for Sheets only) ----
# RECOMMENDED: download the service account JSON key from Google Cloud
# Console (IAM > Service Accounts > Keys > Add key > JSON), save it
# anywhere outside the repo (e.g. C:\Users\Daniel\.gcp\job-agent-key.json),
# and point this env var at it. This avoids all the newline-escaping pain
# of stuffing a PEM block into a single .env line.
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
# FALLBACK: paste the entire JSON on a single line. The private_key's
# newlines must be escaped as literal `\n` (backslash-n, two chars) inside
# the value or you'll get a PEM parse error at first run. Only one of these
# two vars is needed; PATH wins if both are set.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ---- Google Sheets ----
# From sheet URL: docs.google.com/spreadsheets/d/{THIS_PART}/edit
# Share sheet with the service account email (Editor access).
GOOGLE_SHEETS_APPLIED_SHEET_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ

# ---- LinkedIn ----
# RECOMMENDED: paste an active li_at cookie. Avoids LinkedIn's CHALLENGE
# flow which fires when the unofficial API tries to email/password login
# from a new IP. To get it: log into linkedin.com in Chrome, open DevTools
# -> Application -> Cookies -> https://www.linkedin.com, copy the value of
# `li_at` (a long string starting with "AQE..."). Refresh ~quarterly.
LINKEDIN_LI_AT=
# Fallback (used only if LINKEDIN_LI_AT is empty). Will likely fail with
# CHALLENGE on first attempt from any non-LinkedIn-trusted IP.
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your-linkedin-password

# ---- SerpAPI (multi-source Google searches) ----
# Sign up at serpapi.com. Free tier (100/mo) is insufficient — plan to
# upgrade to Developer ($50/mo, 5,000 searches) once verified working.
SERPAPI_KEY=your-serpapi-key

# ---- ClickUp ----
CLICKUP_API_TOKEN=pk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLICKUP_CHAT_CHANNEL_ID=XXXXXXXXXXXXXXXXXX

# ---- Run Settings ----
MAX_APPLICATIONS_PER_RUN=20

# ---- Phase 2 (Playwright auto-apply) ----
# Set DRY_RUN=true for the first 14 working days. While true, every
# apply attempt (LinkedIn API + Playwright) goes through every step
# EXCEPT the final submit, and is logged for review.
DRY_RUN=true

# Resume PDF path, relative to project root.
RESUME_PDF_PATH=resume.pdf
